---
import Breadcrumbs from './Breadcrumbs.astro';
interface Crumb { name: string; href?: string; }
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  crumbs?: Crumb[];
}
const { eyebrow, title, subtitle, crumbs } = Astro.props;
---
<section class="page-hero grain">
  <div class="glow-blobs"></div>
  <div class="container">
    {crumbs && <div class="page-hero-crumbs"><Breadcrumbs crumbs={crumbs} light /></div>}
    {eyebrow && <span class="eyebrow light page-hero-eyebrow">{eyebrow}</span>}
    <h1 class="page-hero-title display sm">{title}</h1>
    {subtitle && <p class="page-hero-sub">{subtitle}</p>}
    <slot />
  </div>
</section>
<style>
  .page-hero { background: var(--color-dark); color: #fff; padding-block: var(--space-3xl); position: relative; overflow: hidden; }
  .page-hero .container { position: relative; z-index: 1; }
  .page-hero-crumbs { margin-bottom: var(--space-lg); }
  .page-hero-eyebrow { margin-bottom: var(--space-sm); }
  .page-hero-title { color: #fff; max-width: 20ch; }
  .page-hero-sub { color: rgba(255,255,255,0.78); font-size: var(--text-lg); max-width: 60ch; margin-top: var(--space-md); }
</style>
