---
import config from '../lib/config';
interface Props {
  reviews?: typeof config.reviews;
  maxReviews?: number;
  heading?: string;
  subtitle?: string;
  compact?: boolean;
  dark?: boolean;
}
const {
  reviews = config.reviews,
  maxReviews = 6,
  heading = 'What clients say',
  subtitle = `${config.trust_signals.rating}-star rated. Real results from the ServiceLine Pro book behind ${config.business.name}.`,
  compact = false,
  dark = false,
} = Astro.props;
const shown = reviews.slice(0, maxReviews);
function initials(name: string) { return name.trim().split(/\s+/).map(w => w[0]).slice(0, 2).join('').toUpperCase(); }
---
<section class:list={['reviews', { dark }]}>
  <div class="container">
    {!compact && (
      <div class="section-header-center">
        <span class="section-label">Proof</span>
        <h2>{heading}</h2>
        <p>{subtitle}</p>
      </div>
    )}
    <div class="reviews-grid">
      {shown.map((r) => (
        <figure class="review-card reveal">
          <div class="review-top">
            <span class="review-avatar">{initials(r.author)}</span>
            <div>
              <figcaption class="review-author">{r.author}</figcaption>
              {r.company && <span class="review-company">{r.company}</span>}
            </div>
          </div>
          <div class="review-stars" aria-label={`${r.rating} out of 5`}>{'★'.repeat(r.rating)}</div>
          <blockquote class="review-text">{r.text}</blockquote>
        </figure>
      ))}
    </div>
    {!compact && (
      <div class="reviews-cta">
        <a href="/reviews/" class="btn btn-outline">Read more results</a>
      </div>
    )}
  </div>
</section>

<style>
  .reviews.dark { background: var(--color-dark); color: rgba(255,255,255,0.8); }
  .reviews-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 640px) { .reviews-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .reviews-grid { grid-template-columns: repeat(3, 1fr); } }
  .review-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm); }
  .reviews.dark .review-card { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
  .review-top { display: flex; align-items: center; gap: 0.75rem; }
  .review-avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--color-primary); color: #fff; display: grid; place-items: center; font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; flex-shrink: 0; }
  .review-author { font-family: var(--font-heading); font-weight: 700; color: var(--color-dark); font-size: 0.95rem; }
  .reviews.dark .review-author { color: #fff; }
  .review-company { font-size: 0.8rem; color: var(--color-text-muted); }
  .reviews.dark .review-company { color: rgba(255,255,255,0.55); }
  .review-stars { color: #ffb400; letter-spacing: 2px; font-size: 0.95rem; }
  .review-text { margin: 0; font-size: 0.95rem; line-height: 1.6; color: var(--color-text-light); border: none; padding: 0; }
  .reviews.dark .review-text { color: rgba(255,255,255,0.75); }
  .reviews-cta { text-align: center; margin-top: var(--space-2xl); }
</style>
