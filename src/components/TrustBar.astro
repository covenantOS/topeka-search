---
import config from '../lib/config';
interface Props { dark?: boolean; }
const { dark = false } = Astro.props;
const badges = config.trust_signals.badges;
const icons: Record<string, string> = {
  default: 'M9 12l2 2 4-4',
};
---
<div class:list={['trust-bar', { dark }]}>
  <div class="container trust-inner">
    {badges.map((b) => (
      <span class="trust-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/>
          <path d={icons.default} stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {b}
      </span>
    ))}
  </div>
</div>
<style>
  .trust-bar { background: var(--color-light); border-block: 1px solid var(--color-gray-200); }
  .trust-bar.dark { background: var(--color-dark); border-color: rgba(255,255,255,0.08); }
  .trust-inner { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem 1.75rem; padding-block: var(--space-md); }
  .trust-badge { display: inline-flex; align-items: center; gap: 0.45rem; font-family: var(--font-heading); font-size: 0.85rem; font-weight: 600; color: var(--color-text); }
  .trust-badge svg { color: var(--color-primary); }
  .trust-bar.dark .trust-badge { color: rgba(255,255,255,0.85); }
  .trust-bar.dark .trust-badge svg { color: var(--color-accent); }
</style>
