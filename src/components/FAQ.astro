---
interface Props {
  heading?: string;
  questions: { question: string; answer: string }[];
}
const { heading = 'Frequently asked questions', questions } = Astro.props;
---
{questions && questions.length > 0 && (
  <section class="faq">
    <h2 class="faq-heading accent-line">{heading}</h2>
    <div class="faq-list">
      {questions.map((q) => (
        <details class="faq-item">
          <summary>
            <span>{q.question}</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer"><p>{q.answer}</p></div>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .faq-heading { margin-bottom: var(--space-xl); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-sm); }
  .faq-item { border: 1px solid var(--color-gray-200); border-radius: var(--radius-md); background: var(--color-white); overflow: hidden; transition: border-color var(--transition-fast); }
  .faq-item[open] { border-color: var(--color-primary); }
  .faq-item summary {
    display: flex; justify-content: space-between; align-items: center; gap: var(--space-md);
    padding: var(--space-lg); cursor: pointer; font-family: var(--font-heading); font-weight: 600;
    font-size: var(--text-lg); color: var(--color-dark); list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-icon { flex-shrink: 0; width: 28px; height: 28px; display: grid; place-items: center; border-radius: 50%; background: var(--color-light); color: var(--color-primary); font-size: 1.2rem; line-height: 1; transition: transform var(--transition-fast); }
  .faq-item[open] .faq-icon { transform: rotate(45deg); }
  .faq-answer { padding: 0 var(--space-lg) var(--space-lg); }
  .faq-answer p { color: var(--color-text-light); line-height: var(--leading-relaxed); margin: 0; max-width: 70ch; }
</style>
