---
/**
 * Word-art wordmark for "Topeka SEO & PPC" + real ServiceLine Pro logo
 * for the "by ServiceLine Pro" endorsement.
 * variant: 'dark' (default, light bg) | 'light' (dark bg)
 */
import config from '../lib/config';
interface Props {
  variant?: 'dark' | 'light';
  href?: string | null;
  showEndorsement?: boolean;
}
const { variant = 'dark', href = '/', showEndorsement = true } = Astro.props;
const slp = variant === 'light' ? config.built_by.logo_white : config.built_by.logo;
const Tag = href ? 'a' : 'div';
---
<Tag {...(href ? { href } : {})} class:list={['wm', variant]} aria-label="Topeka SEO & PPC, by ServiceLine Pro">
  <span class="wm-line">
    <span class="wm-topeka">Topeka</span><span class="wm-svc">SEO&nbsp;&amp;&nbsp;PPC</span>
  </span>
  {showEndorsement && (
    <span class="wm-by">by <img src={`/${slp}`} alt="ServiceLine Pro" height="13" /></span>
  )}
</Tag>

<style>
  .wm { display: inline-flex; flex-direction: column; gap: 3px; text-decoration: none; line-height: 1; }
  .wm-line { font-family: var(--font-heading); font-weight: 800; font-size: 1.32rem; letter-spacing: -0.03em; white-space: nowrap; display: inline-flex; align-items: baseline; gap: 0.32rem; }
  .wm-topeka { color: var(--color-dark); }
  .wm-svc { position: relative; color: var(--color-primary); }
  .wm-svc::after { content: ''; position: absolute; left: -2px; right: -2px; bottom: 1px; height: 6px; background: var(--color-accent); opacity: 0.5; z-index: -1; border-radius: 2px; transform: rotate(-1deg); }
  .wm-by { display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-body); font-size: 0.62rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-text-muted); }
  .wm-by img { display: block; height: 13px; width: auto; }
  .wm.light .wm-topeka { color: #fff; }
  .wm.light .wm-svc { color: #fff; }
  .wm.light .wm-by { color: rgba(255,255,255,0.6); }
  .wm:hover .wm-svc::after { opacity: 0.9; }
</style>
