---
interface Step { title: string; description: string; }
interface Props { heading?: string; steps: Step[]; }
const { heading = 'How it works', steps } = Astro.props;
---
{steps && steps.length > 0 && (
  <section class="process">
    <h2 class="accent-line process-heading">{heading}</h2>
    <ol class="process-list">
      {steps.map((s, i) => (
        <li class="process-step">
          <span class="process-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="process-title">{s.title}</h3>
            <p class="process-desc">{s.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .process-heading { margin-bottom: var(--space-xl); }
  .process-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr; gap: var(--space-lg); counter-reset: step; }
  @media (min-width: 640px) { .process-list { grid-template-columns: 1fr 1fr; } }
  .process-step { display: flex; gap: var(--space-md); align-items: flex-start; padding: var(--space-lg); background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); }
  .process-num { font-family: var(--font-heading); font-weight: 800; font-size: var(--text-2xl); color: var(--color-primary); line-height: 1; opacity: 0.9; }
  .process-title { font-size: var(--text-lg); margin-bottom: var(--space-xs); }
  .process-desc { color: var(--color-text-light); font-size: var(--text-base); line-height: 1.6; margin: 0; }
</style>
