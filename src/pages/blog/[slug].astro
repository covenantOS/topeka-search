---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABand from '../../components/CTABand.astro';
import config from '../../lib/config';
import { parseFrontmatter, renderMarkdown } from '../../lib/markdown';

export function getStaticPaths() {
  const dir = path.resolve('./src/content/blog');
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter(f => f.endsWith('.md')).map((f) => {
    const { data, body } = parseFrontmatter(fs.readFileSync(path.join(dir, f), 'utf8'));
    return { params: { slug: f.replace(/\.md$/, '') }, props: { data, body } };
  });
}

const { data, body } = Astro.props;
const html = renderMarkdown(body);
const siteUrl = `https://${config.seo.domain}`;
const url = `${siteUrl}/blog/${Astro.params.slug}/`;
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: data.title,
    description: data.meta_description || data.excerpt,
    datePublished: data.date,
    author: { '@type': 'Person', name: data.author || config.business.owner },
    publisher: { '@id': `${siteUrl}/#business` },
    mainEntityOfPage: url,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl + '/' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: siteUrl + '/blog/' },
      { '@type': 'ListItem', position: 3, name: data.title, item: url },
    ],
  },
];
---
<Base title={data.meta_title || data.title} description={data.meta_description || data.excerpt} schema={schema} canonical={url}>
  <Header slot="header" />
  <article>
    <header class="post-head">
      <div class="container">
        <Breadcrumbs light crumbs={[{ name: 'Home', href: '/' }, { name: 'Blog', href: '/blog/' }, { name: data.title }]} />
        <h1>{data.title}</h1>
        <p class="post-meta">{data.date} · {data.author || config.business.owner}</p>
      </div>
    </header>
    <div class="section">
      <div class="container post-body">
        <div class="prose" set:html={html} />
      </div>
    </div>
  </article>
  <CTABand showForm={false} />
  <Footer slot="footer" />
</Base>
<style>
  .post-head { background: var(--color-dark); color: #fff; padding-block: var(--space-2xl); position: relative; overflow: hidden; }
  .post-head::after { content: ''; position: absolute; inset: 0; background: radial-gradient(55% 80% at 85% 0%, rgba(var(--color-primary-rgb), 0.3), transparent 60%); pointer-events: none; }
  .post-head .container { position: relative; z-index: 1; }
  .post-head h1 { color: #fff; margin-top: var(--space-md); max-width: 22ch; }
  .post-meta { color: rgba(255,255,255,0.65); margin-top: var(--space-sm); font-size: 0.9rem; }
  .post-body { max-width: 760px; }
</style>
