---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import config from '../lib/config';
import { servicePath } from '../lib/config';

const { phone, phone_raw } = config.business;
const claimed = config.exclusivity?.claimed || [];
const FEATURED = ['seo', 'google-ads-management', 'web-design'];
const trio = FEATURED.map((s) => config.services.find((x) => x.slug === s)).filter(Boolean) as typeof config.services;
const reviews = config.reviews.slice(0, 6);
const initials = (n: string) => n.trim().split(/\s+/).map(w => w[0]).slice(0, 2).join('').toUpperCase();

const title = 'Topeka SEO, Google Ads & Web Design | Topeka SEO & PPC';
const description = 'Topeka SEO, Google Ads, and web design built to scale your business from $1M to $10M. Top-3 rankings, prices upfront, $0 agency fee on Google Ads. One client per industry in Topeka.';
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero grain">
    <div class="glow-blobs"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow rise" style="--d:0ms">Topeka SEO &amp; PPC · by ServiceLine Pro</span>
        <h1 class="display">
          <span class="rise" style="--d:80ms">Get your Topeka business to the</span>
          <span class="rise" style="--d:180ms"><span class="mark">top of Google</span></span>
          <span class="rise" style="--d:280ms">and scale it to <span class="ink">$10M</span></span>
        </h1>
        <p class="hero-sub rise" style="--d:400ms">SEO, Google Ads, and web design for one local business per industry in Topeka. Top-3 rankings, prices published upfront, and a $0 agency fee on Google Ads.</p>
        <div class="hero-actions rise" style="--d:500ms">
          <a href="/contact/" class="btn btn-primary btn-lg">Get My Free Plan</a>
          <a href={`tel:${phone_raw}`} class="btn btn-outline btn-lg">Call {phone}</a>
        </div>
        <div class="hero-tags rise" style="--d:600ms">
          <span><b>★ 5.0</b> Google rating</span>
          <span><b>Prices</b> on the page</span>
          <span><b>1</b> client per industry</span>
        </div>
      </div>

      <div class="hero-art rise" style="--d:350ms">
        <div class="guarantee">
          <span class="g-badge">The guarantee</span>
          <p class="g-line">Top 3 in the Google Map Pack within <span class="ink">90 days</span>, or you don't pay.</p>
          <div class="g-rank">
            <div class="g-row win"><span class="g-pin">1</span><span class="g-name">Your business</span><span class="g-tag">You</span></div>
            <div class="g-row"><span class="g-pin muted">2</span><span class="g-name muted">A competitor</span></div>
            <div class="g-row"><span class="g-pin muted">3</span><span class="g-name muted">A competitor</span></div>
          </div>
        </div>
        <div class="float-chip chip-fee">$0 agency fee on Google Ads</div>
        <div class="float-chip chip-rev">$2M+ in client pipeline</div>
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee promo-marquee">
    <div class="marquee-track">
      {Array.from({length: 2}).map(() => (
        <Fragment>
          <span class="marquee-item">Prices Upfront<span class="marquee-dot"></span></span>
          <span class="marquee-item">$0 Agency Fee on Ads<span class="marquee-dot"></span></span>
          <span class="marquee-item">One Client Per Industry<span class="marquee-dot"></span></span>
          <span class="marquee-item">Top 3 or You Don't Pay<span class="marquee-dot"></span></span>
          <span class="marquee-item">Built by ServiceLine Pro<span class="marquee-dot"></span></span>
        </Fragment>
      ))}
    </div>
  </div>

  <!-- 3 SERVICES -->
  <section class="section trio-sec">
    <div class="container">
      <div class="trio-head">
        <div>
          <span class="eyebrow">What we do</span>
          <h2 class="display sm">Three things we <span class="mark">live and breathe</span></h2>
        </div>
        <p>SEO, Google Ads, and web design are the engine. We run other channels too, but these three are what we rank, run, and stake our name on.</p>
      </div>
      <div class="trio-grid">
        {trio.map((s, i) => (
          <a href={servicePath(s.slug)} class="trio-card reveal">
            <span class="trio-num">0{i + 1}</span>
            <span class="trio-icon"><Icon name={s.icon} size={28} /></span>
            <h3>{s.nav_name || s.name}</h3>
            <p>{s.short_description}</p>
            <div class="trio-foot"><span class="trio-price">{s.price_summary}</span><span class="link-arrow">See details</span></div>
          </a>
        ))}
      </div>
      <p class="trio-all"><a href="/pricing/" class="link-arrow">See all services &amp; pricing</a></p>
    </div>
  </section>

  <!-- EXCLUSIVITY STATEMENT -->
  <section class="section excl-band grain">
    <div class="container excl-inner">
      <div class="excl-copy">
        <span class="eyebrow light">One client per industry</span>
        <h2 class="display sm">When your category in Topeka is <span class="mark">claimed, it's gone.</span></h2>
        <p>We only work with one business per industry here. We will never run the same playbook for the competitor down the street. A few categories are already taken:</p>
        <a href="/contact/" class="btn btn-accent btn-lg">Check if your category is open</a>
      </div>
      <div class="excl-list">
        {claimed.map((c) => (<div class="excl-item taken"><span>{c}</span><span class="excl-flag">Claimed</span></div>))}
        <div class="excl-item open"><span>Your industry?</span><span class="excl-flag-open">Open →</span></div>
      </div>
    </div>
  </section>

  <!-- RESULTS / COUNTERS -->
  <section class="section results-sec">
    <div class="container">
      <div class="results-head">
        <span class="eyebrow">The receipts</span>
        <h2 class="display sm">Real results we've put on the board</h2>
        <p>We run the ServiceLine Pro playbook. These are real client outcomes, the kind we bring to Topeka.</p>
      </div>
      <div class="counters">
        <div class="counter"><span class="count" data-to="2" data-prefix="$" data-suffix="M+">$0</span><span class="counter-label">in new business for one client</span></div>
        <div class="counter"><span class="count" data-to="300" data-suffix="+">0</span><span class="counter-label">leads from one campaign</span></div>
        <div class="counter"><span class="count" data-to="200" data-suffix="%">0</span><span class="counter-label">revenue increase</span></div>
        <div class="counter"><span class="count plain">Top 3</span><span class="counter-label">Map Pack rankings</span></div>
      </div>
      <div class="case-row">
        {config.case_studies.slice(0,3).map((cs) => (
          <article class="case-card reveal">
            <span class="case-cat">{cs.category}</span>
            <span class="case-primary">{cs.metrics?.primary || cs.result}</span>
            <span class="case-secondary">{cs.metrics?.secondary}</span>
            <span class="case-name">{cs.title}</span>
          </article>
        ))}
      </div>
      <div class="results-cta"><a href="/case-studies/" class="link-arrow">See all the case studies</a></div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section section-alt reviews-sec">
    <div class="container">
      <div class="results-head">
        <span class="eyebrow">Word of mouth</span>
        <h2 class="display sm">Clients don't hold back</h2>
      </div>
      <div class="rev-grid">
        {reviews.map((r) => (
          <figure class="rev-card reveal">
            <div class="rev-stars">★★★★★</div>
            <blockquote>{r.text}</blockquote>
            <figcaption><span class="rev-av">{initials(r.author)}</span><span><b>{r.author}</b>{r.company && <em>{r.company}</em>}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL -->
  <section class="section local">
    <div class="container local-inner">
      <figure class="local-photo">
        <img src="/media/team/victoria-hamilton.webp" alt="Victoria Hamilton, your local Topeka rep" width="540" height="570" />
      </figure>
      <div class="local-copy">
        <span class="eyebrow">Local, on purpose</span>
        <h2 class="display sm">A real person in Topeka on your account.</h2>
        <p>We're a family operation. Founder William Hamilton is a Topeka native, and his sister Victoria is your rep on the ground here. Call us and you reach someone who knows Topeka and knows your account, not a ticket queue.</p>
        <a href="/about/" class="link-arrow">More about us</a>
      </div>
    </div>
  </section>

  <CTABand showForm={true} />
  <Footer slot="footer" />
</Base>

<script>
  // Count-up animation
  const counters = document.querySelectorAll('.count[data-to]');
  const run = (el) => {
    const to = parseFloat(el.getAttribute('data-to'));
    const pre = el.getAttribute('data-prefix') || '';
    const suf = el.getAttribute('data-suffix') || '';
    const dur = 1400; const start = performance.now();
    const step = (t) => {
      const p = Math.min(1, (t - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = to >= 100 ? Math.round(to * eased) : (to * eased).toFixed(1).replace(/\.0$/, '');
      el.textContent = pre + val + suf;
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { run(e.target); io.unobserve(e.target); } }), { threshold: 0.4 });
    counters.forEach((c) => io.observe(c));
  } else { counters.forEach(run); }
</script>

<style>
  /* HERO */
  .hero { position: relative; background: var(--color-light); padding-block: var(--space-3xl) var(--space-4xl); overflow: hidden; }
  .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr; gap: var(--space-3xl); align-items: center; }
  @media (min-width: 1000px) { .hero-inner { grid-template-columns: 1.1fr 0.9fr; } }
  .hero h1.display { margin-bottom: var(--space-lg); }
  .hero h1.display span { display: block; }
  .hero-sub { font-size: var(--text-lg); color: var(--color-text-light); max-width: 52ch; margin-bottom: var(--space-xl); }
  .hero-actions { display: flex; flex-wrap: wrap; gap: var(--space-md); margin-bottom: var(--space-xl); }
  .hero-tags { display: flex; flex-wrap: wrap; gap: 1.25rem 2rem; }
  .hero-tags span { font-size: 0.9rem; color: var(--color-text-muted); }
  .hero-tags b { color: var(--color-dark); font-family: var(--font-heading); }

  .hero-art { position: relative; min-height: 360px; }
  .guarantee { position: relative; z-index: 2; background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); padding: var(--space-xl); max-width: 420px; margin-inline: auto; }
  .g-badge { display: inline-block; font-family: var(--font-heading); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary); background: rgba(var(--color-primary-rgb),0.08); padding: 0.3rem 0.7rem; border-radius: var(--radius-pill); margin-bottom: var(--space-md); }
  .g-line { font-family: var(--font-heading); font-weight: 800; font-size: 1.4rem; line-height: 1.2; letter-spacing: -0.02em; color: var(--color-dark); margin-bottom: var(--space-lg); }
  .g-rank { display: flex; flex-direction: column; gap: 0.5rem; }
  .g-row { display: flex; align-items: center; gap: 0.7rem; padding: 0.6rem 0.7rem; border-radius: var(--radius-md); background: var(--color-gray-100); }
  .g-row.win { background: rgba(var(--color-accent-rgb),0.14); border: 1px solid var(--color-accent); }
  .g-pin { width: 26px; height: 26px; border-radius: 50%; background: var(--color-primary); color: #fff; display: grid; place-items: center; font-family: var(--font-heading); font-weight: 800; font-size: 0.8rem; flex-shrink: 0; }
  .g-pin.muted { background: var(--color-gray-300); color: var(--color-gray-600); }
  .g-name { font-family: var(--font-heading); font-weight: 700; color: var(--color-dark); font-size: 0.9rem; flex: 1; }
  .g-name.muted { color: var(--color-gray-500); font-weight: 600; }
  .g-tag { background: var(--color-accent); color: var(--color-dark); font-family: var(--font-heading); font-weight: 800; font-size: 0.68rem; padding: 0.15rem 0.5rem; border-radius: var(--radius-pill); }
  .float-chip { position: absolute; z-index: 3; background: var(--color-dark); color: #fff; font-family: var(--font-heading); font-weight: 700; font-size: 0.82rem; padding: 0.6rem 1rem; border-radius: var(--radius-pill); box-shadow: var(--shadow-md); white-space: nowrap; }
  .chip-fee { top: 4%; left: -2%; background: var(--color-primary); }
  .chip-rev { bottom: 6%; right: -2%; }
  @media (prefers-reduced-motion: no-preference) {
    .float-chip { animation: floaty 4s ease-in-out infinite; }
    .chip-rev { animation-delay: 1.5s; }
    @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-9px); } }
  }
  @media (max-width: 560px) { .float-chip { display: none; } }

  /* MARQUEE */
  .promo-marquee { background: var(--color-dark); padding-block: var(--space-md); border-block: 3px solid var(--color-primary); }
  .promo-marquee .marquee-item { color: #fff; font-size: clamp(1rem, 2.4vw, 1.5rem); }
  .promo-marquee .marquee-dot { background: var(--color-accent); }

  /* TRIO */
  .trio-head { display: grid; grid-template-columns: 1fr; gap: var(--space-md); margin-bottom: var(--space-2xl); align-items: end; }
  @media (min-width: 900px) { .trio-head { grid-template-columns: 1.3fr 1fr; } .trio-head p { text-align: right; } }
  .trio-head h2 { margin: 0.5rem 0 0; }
  .trio-head p { color: var(--color-text-light); margin: 0; }
  .trio-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 768px) { .trio-grid { grid-template-columns: repeat(3, 1fr); } }
  .trio-card { position: relative; display: flex; flex-direction: column; gap: 0.6rem; padding: var(--space-xl); background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); color: var(--color-text); transition: all var(--transition-base); overflow: hidden; }
  .trio-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--color-primary); transform: scaleX(0); transform-origin: left; transition: transform var(--transition-base); }
  .trio-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card-hover); border-color: var(--color-primary); color: var(--color-text); }
  .trio-card:hover::before { transform: scaleX(1); }
  .trio-num { position: absolute; top: var(--space-md); right: var(--space-lg); font-family: var(--font-heading); font-weight: 800; font-size: var(--text-3xl); color: var(--color-gray-200); }
  .trio-icon { width: 56px; height: 56px; border-radius: 16px; background: rgba(var(--color-primary-rgb), 0.09); color: var(--color-primary); display: grid; place-items: center; transition: all var(--transition-base); }
  .trio-card:hover .trio-icon { background: var(--color-primary); color: #fff; transform: rotate(-6deg); }
  .trio-card h3 { font-size: var(--text-xl); margin: 0; }
  .trio-card p { color: var(--color-text-light); font-size: 0.93rem; line-height: 1.55; margin: 0; flex: 1; }
  .trio-foot { display: flex; align-items: center; justify-content: space-between; margin-top: var(--space-sm); padding-top: var(--space-md); border-top: 1px solid var(--color-gray-100); }
  .trio-price { font-family: var(--font-heading); font-weight: 800; color: var(--color-primary); font-size: 1.05rem; }
  .trio-foot .link-arrow { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 600; }
  .trio-card:hover .trio-foot .link-arrow { color: var(--color-primary); }
  .trio-all { text-align: center; margin-top: var(--space-xl); }
  .trio-all .link-arrow { font-weight: 800; color: var(--color-primary); }

  /* EXCLUSIVITY BAND */
  .excl-band { position: relative; background: var(--color-dark); color: rgba(255,255,255,0.82); overflow: hidden; }
  .excl-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; }
  @media (min-width: 900px) { .excl-inner { grid-template-columns: 1.2fr 0.8fr; } }
  .excl-band h2 { color: #fff; margin: 0.5rem 0 var(--space-md); }
  .eyebrow.light { color: var(--color-accent); }
  .eyebrow.light::before { background: var(--color-accent); }
  .excl-copy p { color: rgba(255,255,255,0.72); margin-bottom: var(--space-lg); max-width: 52ch; }
  .excl-list { display: flex; flex-direction: column; gap: 0.55rem; }
  .excl-item { display: flex; justify-content: space-between; align-items: center; padding: 0.95rem 1.2rem; border-radius: var(--radius-md); font-family: var(--font-heading); font-weight: 700; }
  .excl-item.taken { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.55); }
  .excl-item.taken .excl-flag { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; color: rgba(255,255,255,0.4); }
  .excl-item.open { background: var(--color-accent); color: var(--color-dark); }
  .excl-flag-open { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; }

  /* RESULTS */
  .results-head { max-width: 640px; margin-bottom: var(--space-2xl); }
  .results-head h2 { margin: 0.5rem 0 var(--space-sm); }
  .results-head p { color: var(--color-text-light); }
  .counters { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); margin-bottom: var(--space-2xl); }
  @media (min-width: 768px) { .counters { grid-template-columns: repeat(4, 1fr); } }
  .counter { text-align: center; padding: var(--space-lg) var(--space-md); border-left: 3px solid var(--color-primary); }
  .counter .count { display: block; font-size: clamp(2.2rem, 5vw, 3.2rem); }
  .counter .count.plain { color: var(--color-primary); }
  .counter-label { display: block; font-size: 0.85rem; color: var(--color-text-muted); margin-top: 0.3rem; }
  .case-row { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 768px) { .case-row { grid-template-columns: repeat(3, 1fr); } }
  .case-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); padding: var(--space-xl); display: flex; flex-direction: column; gap: 0.25rem; border-top: 4px solid var(--color-primary); transition: all var(--transition-base); }
  .case-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); }
  .case-cat { font-family: var(--font-heading); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-primary); }
  .case-primary { font-family: var(--font-heading); font-weight: 800; font-size: var(--text-2xl); color: var(--color-dark); letter-spacing: -0.02em; line-height: 1.1; margin-top: 0.3rem; }
  .case-secondary { color: var(--color-text-muted); font-weight: 600; font-size: 0.9rem; }
  .case-name { font-size: 0.85rem; color: var(--color-text-faint); margin-top: var(--space-sm); }
  .results-cta { margin-top: var(--space-xl); }
  .results-cta .link-arrow { font-weight: 800; color: var(--color-primary); }

  /* REVIEWS */
  .reviews-sec .rev-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 700px) { .reviews-sec .rev-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .reviews-sec .rev-grid { grid-template-columns: repeat(3, 1fr); } }
  .rev-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm); }
  .rev-stars { color: var(--color-accent); letter-spacing: 2px; }
  .rev-card blockquote { margin: 0; border: 0; padding: 0; font-size: 0.97rem; line-height: 1.6; color: var(--color-text); }
  .rev-card figcaption { display: flex; align-items: center; gap: 0.6rem; margin-top: auto; padding-top: var(--space-sm); }
  .rev-av { width: 38px; height: 38px; border-radius: 50%; background: var(--color-primary); color: #fff; display: grid; place-items: center; font-family: var(--font-heading); font-weight: 700; font-size: 0.8rem; }
  .rev-card figcaption b { display: block; font-family: var(--font-heading); font-size: 0.9rem; color: var(--color-dark); }
  .rev-card figcaption em { font-style: normal; font-size: 0.78rem; color: var(--color-text-muted); }

  /* LOCAL */
  .local-inner { display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; }
  @media (min-width: 900px) { .local-inner { grid-template-columns: 0.8fr 1.2fr; } }
  .local-photo { margin: 0; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); max-width: 360px; }
  .local-photo img { width: 100%; height: auto; display: block; }
  .local-copy h2 { margin: 0.5rem 0 var(--space-md); }
  .local-copy p { color: var(--color-text-light); margin-bottom: var(--space-md); }
  .display.sm { font-size: clamp(1.9rem, 4vw, 2.9rem); }
</style>
