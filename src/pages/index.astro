---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABand from '../components/CTABand.astro';
import Icon from '../components/Icon.astro';
import config from '../lib/config';
import { servicePath } from '../lib/config';

const { phone, phone_raw } = config.business;
const claimed = config.exclusivity?.claimed || [];
const FEATURED = ['seo', 'google-ads-management', 'web-design'];
const trio = FEATURED.map((s) => config.services.find((x) => x.slug === s)).filter(Boolean) as typeof config.services;
const reviews = config.reviews.slice(0, 6);
const cases = config.case_studies.slice(0, 6);
const initials = (n: string) => n.trim().split(/\s+/).map(w => w[0]).slice(0, 2).join('').toUpperCase();
const ytId = 'xIJm909iEm4';

const title = 'Topeka SEO, Google Ads & Web Design | Topeka SEO & PPC';
const description = 'Local SEO that grows Topeka businesses from $1M to $10M. SEO, Google Ads, and web design with prices upfront and a $0 agency fee on Google Ads. One client per industry in Topeka, KS.';
---

<Base title={title} description={description}>
  <Header slot="header" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/imagery/topeka-capitol.webp')"></div>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="hero-ribbon">
          <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.998 10.998 0 0012 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09 0-.73.13-1.43.35-2.09V7.07H2.18A10.998 10.998 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span class="ribbon-stars">★★★★★</span>
          <strong>{config.trust_signals.rating}</strong> <span class="ribbon-sub">· verified Google reviews</span>
        </span>

        <h1>Topeka <span class="accent">SEO</span>, <span class="accent">Google Ads</span> &amp; <span class="accent">web design</span> that get the phone ringing.</h1>
        <p class="hero-sub">We get one local business per industry <strong>found first</strong> in Topeka, then turn those searches into <strong>booked calls</strong>. Prices on the page. A $0 agency fee on Google Ads.</p>

        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Get My Free Plan</a>
          <a href="/pricing/" class="hero-link">See all services &amp; pricing →</a>
        </div>
      </div>

      <div class="hero-video">
        <button class="lite-yt" data-yt={ytId} aria-label="Play the overview video">
          <img src={`https://i.ytimg.com/vi/${ytId}/sddefault.jpg`} alt="Watch the overview" loading="eager"
               onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/${ytId}/hqdefault.jpg'" />
          <span class="yt-grad"></span>
          <span class="yt-label"><span class="yt-dot"></span> Watch the overview</span>
          <span class="yt-play"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></span>
        </button>
      </div>
    </div>
  </section>

  <!-- TRUSTED-BY LOGOS -->
  <section class="logos-band">
    <div class="container">
      <p class="logos-label">Trusted by &amp; built on the platforms that matter</p>
      <div class="logos-row">
        <span class="tlogo" title="Google"><svg viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.998 10.998 0 0012 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09 0-.73.13-1.43.35-2.09V7.07H2.18A10.998 10.998 0 001 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg><span class="gword"><span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span></span></span>
        <span class="tlogo" title="ChatGPT"><svg viewBox="0 0 41 41" fill="#10A37F" aria-hidden="true"><path d="M37.532 16.87a9.963 9.963 0 0 0-.856-8.184 10.078 10.078 0 0 0-10.855-4.835A9.964 9.964 0 0 0 18.306.5a10.079 10.079 0 0 0-9.614 6.977 9.967 9.967 0 0 0-6.664 4.834 10.08 10.08 0 0 0 1.24 11.817 9.965 9.965 0 0 0 .856 8.185 10.079 10.079 0 0 0 10.855 4.835 9.965 9.965 0 0 0 7.516 3.35 10.078 10.078 0 0 0 9.614-6.981 9.97 9.97 0 0 0 6.664-4.834 10.08 10.08 0 0 0-1.241-11.813ZM22.498 37.886a7.474 7.474 0 0 1-4.799-1.735c.061-.033.168-.091.237-.134l7.964-4.6a1.294 1.294 0 0 0 .655-1.134v-11.232l3.366 1.945a.12.12 0 0 1 .066.092v9.299a7.505 7.505 0 0 1-7.49 7.499ZM6.392 31.006a7.471 7.471 0 0 1-.894-5.023c.06.036.162.099.237.142l7.964 4.6a1.297 1.297 0 0 0 1.308 0l9.724-5.614v3.888a.12.12 0 0 1-.048.103l-8.051 4.649a7.504 7.504 0 0 1-10.24-2.745ZM4.297 13.62A7.469 7.469 0 0 1 8.197 10.34c0 .069-.004.19-.004.275v9.201a1.294 1.294 0 0 0 .654 1.132l9.724 5.614-3.366 1.945a.12.12 0 0 1-.114.01L7.04 23.86a7.504 7.504 0 0 1-2.743-10.24Zm27.658 6.437-9.724-5.615 3.367-1.944a.121.121 0 0 1 .113-.01l8.052 4.649a7.498 7.498 0 0 1-1.158 13.528v-9.477a1.293 1.293 0 0 0-.65-1.131Zm3.35-5.043c-.059-.037-.162-.099-.236-.141l-7.965-4.6a1.298 1.298 0 0 0-1.308 0l-9.723 5.614v-3.888a.12.12 0 0 1 .048-.103l8.05-4.645a7.497 7.497 0 0 1 11.135 7.763Zm-21.063 6.929-3.367-1.944a.12.12 0 0 1-.065-.092v-9.299a7.497 7.497 0 0 1 12.293-5.756 6.94 6.94 0 0 0-.236.134l-7.965 4.6a1.294 1.294 0 0 0-.654 1.132l-.006 11.225Zm1.829-3.943 4.33-2.501 4.332 2.5v5l-4.331 2.5-4.331-2.5V17.5Z"/></svg><span class="tlabel">ChatGPT</span></span>
        <span class="tlogo" title="Apple"><svg viewBox="0 0 24 24" fill="#1F1F1F" aria-hidden="true"><path d="M17.05 12.5a4.5 4.5 0 012.16-3.78 4.6 4.6 0 00-3.62-1.96c-1.53-.16-3 .91-3.78.91-.79 0-1.99-.89-3.27-.86a4.83 4.83 0 00-4.06 2.48c-1.74 3.02-.45 7.49 1.24 9.94.83 1.2 1.81 2.55 3.09 2.5 1.24-.05 1.71-.81 3.21-.81 1.5 0 1.92.81 3.23.78 1.34-.02 2.18-1.21 3-2.42a10.6 10.6 0 001.36-2.79 4.4 4.4 0 01-2.56-4.0zM14.6 5.1a4.4 4.4 0 001.01-3.13 4.45 4.45 0 00-2.93 1.5 4.16 4.16 0 00-1.04 3.04 3.69 3.69 0 002.96-1.41z"/></svg><span class="tlabel">Apple</span></span>
        <span class="tlogo" title="Yelp"><img src="/imagery/badges/yelp-full-color.png" alt="Yelp" height="28" /></span>
      </div>
    </div>
  </section>

  <!-- 3 SERVICES -->
  <section class="section trio-sec">
    <div class="container">
      <div class="trio-head">
        <div>
          <span class="eyebrow">What we do</span>
          <h2 class="display sm">Three things we live and breathe</h2>
        </div>
        <p>SEO, Google Ads, and web design are the engine. We run other channels too, but these three are what we rank, run, and stake our name on.</p>
      </div>
      <div class="trio-grid">
        {trio.map((s, i) => (
          <a href={servicePath(s.slug)} class="trio-card reveal">
            <span class="trio-num">0{i + 1}</span>
            <span class="trio-icon"><Icon name={s.icon} size={28} /></span>
            <h3>{s.nav_name || s.name}</h3>
            <p>{s.short_description}</p>
            <div class="trio-foot"><span class="trio-price">{s.price_summary}</span><span class="link-arrow">See details</span></div>
          </a>
        ))}
      </div>
      <p class="trio-all"><a href="/pricing/" class="link-arrow">See all services &amp; pricing</a></p>
    </div>
  </section>

  <!-- RESULTS with real screenshots -->
  <section class="section section-alt results-sec">
    <div class="container">
      <div class="results-head">
        <span class="eyebrow">The receipts</span>
        <h2 class="display sm">Real results we've put on the board</h2>
        <p>We run the ServiceLine Pro playbook. Real client outcomes, the kind we bring to Topeka.</p>
      </div>
      <div class="case-grid">
        {cases.map((cs) => (
          <article class="case-card reveal">
            {cs.image && <div class="case-shot"><img src={`/${cs.image}`} alt={`${cs.title} results`} width="600" height="380" loading="lazy" /></div>}
            <div class="case-body">
              <span class="case-cat">{cs.category}</span>
              <span class="case-primary">{cs.metrics?.primary || cs.result}</span>
              <span class="case-secondary">{cs.metrics?.secondary}</span>
              <span class="case-name">{cs.title}</span>
            </div>
          </article>
        ))}
      </div>
      <div class="results-cta"><a href="/case-studies/" class="link-arrow">See all the case studies</a></div>
    </div>
  </section>

  <!-- EXCLUSIVITY -->
  <section class="section excl-band">
    <div class="container excl-inner">
      <div class="excl-copy">
        <span class="eyebrow light">One client per industry</span>
        <h2 class="display sm">When your category in Topeka is claimed, it's gone.</h2>
        <p>We only work with one business per industry here. We will never run the same playbook for the competitor down the street. A few categories are already taken:</p>
        <a href="/contact/" class="btn btn-accent btn-lg">Check if your category is open</a>
      </div>
      <div class="excl-list">
        {claimed.map((c) => (<div class="excl-item taken"><span>{c}</span><span class="excl-flag">Claimed</span></div>))}
        <div class="excl-item open"><span>Your industry?</span><span class="excl-flag-open">Open →</span></div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section reviews-sec">
    <div class="container">
      <div class="results-head">
        <span class="eyebrow">Word of mouth</span>
        <h2 class="display sm">Clients don't hold back</h2>
      </div>
      <div class="rev-grid">
        {reviews.map((r) => (
          <figure class="rev-card reveal">
            <div class="rev-stars">★★★★★</div>
            <blockquote>{r.text}</blockquote>
            <figcaption><span class="rev-av">{initials(r.author)}</span><span><b>{r.author}</b>{r.company && <em>{r.company}</em>}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL -->
  <section class="section section-alt local">
    <div class="container local-inner">
      <figure class="local-photo">
        <img src="/media/team/victoria-hamilton.webp" alt="Victoria Hamilton, your local Topeka rep" width="540" height="570" loading="lazy" />
      </figure>
      <div class="local-copy">
        <span class="eyebrow">Local, on purpose</span>
        <h2 class="display sm">A real person in Topeka on your account.</h2>
        <p>We're a family operation. Founder William Hamilton is a Topeka native, and his sister Victoria is your rep on the ground here. Call us and you reach someone who knows Topeka and knows your account, not a ticket queue.</p>
        <a href="/about/" class="link-arrow">More about us</a>
      </div>
    </div>
  </section>

  <CTABand showForm={true} />
  <Footer slot="footer" />
</Base>

<script>
  document.querySelectorAll('.lite-yt').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-yt');
      const f = document.createElement('iframe');
      f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      f.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      f.allowFullscreen = true;
      f.className = 'yt-frame';
      el.replaceWith(f);
    });
  });
</script>

<style>
  /* HERO */
  .hero { position: relative; color: #fff; overflow: hidden; background: var(--color-dark); }
  .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center 30%; }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(105deg, rgba(20,16,14,0.94) 0%, rgba(20,16,14,0.86) 42%, rgba(26,18,15,0.62) 100%); }
  .hero::after { content: ''; position: absolute; top: -20%; right: -10%; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(var(--color-primary-rgb),0.30), transparent 65%); pointer-events: none; }
  .hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr; gap: var(--space-2xl); align-items: center; padding-block: var(--space-3xl) var(--space-4xl); min-height: 72vh; }
  @media (min-width: 1000px) { .hero-inner { grid-template-columns: 1.15fr 0.85fr; gap: var(--space-3xl); } }

  .hero-ribbon { display: inline-flex; align-items: center; gap: 0.45rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.16); padding: 0.4rem 0.85rem; border-radius: var(--radius-pill); font-size: 0.85rem; backdrop-filter: blur(8px); }
  .hero-ribbon .ribbon-stars { color: var(--color-accent); letter-spacing: 1px; }
  .hero-ribbon strong { color: #fff; }
  .hero-ribbon .ribbon-sub { color: rgba(255,255,255,0.7); }

  .hero h1 { color: #fff; font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.08; letter-spacing: -0.03em; font-weight: 800; margin: var(--space-lg) 0 var(--space-md); max-width: 16ch; }
  .hero h1 .hl { color: var(--color-accent); }
  .hero h1 .accent { color: var(--color-primary-light); white-space: nowrap; }
  .hero-sub { color: rgba(255,255,255,0.82); font-size: var(--text-lg); max-width: 50ch; margin-bottom: var(--space-xl); }
  .hero-sub strong { color: #fff; }
  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-lg); margin-bottom: var(--space-xl); }
  .hero-link { color: #fff; font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem; }
  .hero-link:hover { color: var(--color-accent); }
  .hero-partners { display: flex; align-items: center; gap: 0.9rem; }
  .partners-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.55); font-weight: 600; }
  .partners-icons { display: inline-flex; align-items: center; gap: 0.9rem; }
  .partners-icons svg, .partners-icons img { width: 22px; height: 22px; display: block; opacity: 0.92; }

  .hero-video { display: block; }
  .lite-yt { display: block; width: 100%; aspect-ratio: 16/9; position: relative; border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 24px 60px -20px rgba(0,0,0,0.6); cursor: pointer; padding: 0; background: #000; }
  .lite-yt img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .yt-grad { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.1), rgba(0,0,0,0.45)); }
  .yt-label { position: absolute; top: 0.8rem; left: 0.8rem; display: inline-flex; align-items: center; gap: 0.4rem; background: rgba(0,0,0,0.65); color: #fff; font-size: 0.72rem; font-weight: 600; padding: 0.3rem 0.7rem; border-radius: var(--radius-pill); backdrop-filter: blur(6px); }
  .yt-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary-light); animation: ytpulse 1.6s infinite; }
  @keyframes ytpulse { 50% { opacity: 0.3; } }
  .yt-play { position: absolute; inset: 0; display: grid; place-items: center; }
  .yt-play svg { width: 30px; height: 30px; color: #fff; margin-left: 4px; }
  .yt-play::before { content: ''; position: absolute; width: 78px; height: 78px; border-radius: 50%; background: rgba(var(--color-primary-rgb),0.95); box-shadow: 0 12px 40px rgba(var(--color-primary-rgb),0.45); transition: transform var(--transition-base); }
  .lite-yt:hover .yt-play::before { transform: scale(1.08); }
  :global(.yt-frame) { width: 100%; aspect-ratio: 16/9; border: 0; border-radius: var(--radius-lg); }

  /* LOGOS BAND */
  .logos-band { background: var(--color-white); border-bottom: 1px solid var(--color-gray-200); padding-block: var(--space-xl); }
  .logos-label { text-align: center; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); font-weight: 700; margin-bottom: var(--space-md); }
  .logos-row { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 1.25rem 2.5rem; }
  .logos-row .tlogo { display: inline-flex; align-items: center; gap: 0.5rem; opacity: 0.9; }
  .logos-row .tlogo svg { width: 26px; height: 26px; }
  .logos-row .tlogo img { height: 28px; width: auto; display: block; }
  .logos-row .gword { font-family: arial, sans-serif; font-weight: 500; font-size: 1.35rem; letter-spacing: -0.01em; }
  .logos-row .tlabel { font-family: var(--font-heading); font-weight: 600; font-size: 1.05rem; color: #3c3c3c; }

  /* TRIO */
  .trio-head { display: grid; grid-template-columns: 1fr; gap: var(--space-md); margin-bottom: var(--space-2xl); align-items: end; }
  @media (min-width: 900px) { .trio-head { grid-template-columns: 1.3fr 1fr; } .trio-head p { text-align: right; } }
  .trio-head h2 { margin: 0.5rem 0 0; }
  .trio-head p { color: var(--color-text-light); margin: 0; }
  .trio-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 768px) { .trio-grid { grid-template-columns: repeat(3, 1fr); } }
  .trio-card { position: relative; display: flex; flex-direction: column; gap: 0.6rem; padding: var(--space-xl); background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); color: var(--color-text); transition: all var(--transition-base); overflow: hidden; }
  .trio-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: var(--color-primary); transform: scaleX(0); transform-origin: left; transition: transform var(--transition-base); }
  .trio-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-card-hover); border-color: var(--color-primary); color: var(--color-text); }
  .trio-card:hover::before { transform: scaleX(1); }
  .trio-num { position: absolute; top: var(--space-md); right: var(--space-lg); font-family: var(--font-heading); font-weight: 800; font-size: var(--text-3xl); color: var(--color-gray-200); }
  .trio-icon { width: 56px; height: 56px; border-radius: 16px; background: rgba(var(--color-primary-rgb), 0.09); color: var(--color-primary); display: grid; place-items: center; transition: all var(--transition-base); }
  .trio-card:hover .trio-icon { background: var(--color-primary); color: #fff; transform: rotate(-6deg); }
  .trio-card h3 { font-size: var(--text-xl); margin: 0; }
  .trio-card p { color: var(--color-text-light); font-size: 0.93rem; line-height: 1.55; margin: 0; flex: 1; }
  .trio-foot { display: flex; align-items: center; justify-content: space-between; margin-top: var(--space-sm); padding-top: var(--space-md); border-top: 1px solid var(--color-gray-100); }
  .trio-price { font-family: var(--font-heading); font-weight: 800; color: var(--color-primary); font-size: 1.05rem; }
  .trio-foot .link-arrow { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 600; }
  .trio-card:hover .trio-foot .link-arrow { color: var(--color-primary); }
  .trio-all { text-align: center; margin-top: var(--space-xl); }
  .trio-all .link-arrow { font-weight: 800; color: var(--color-primary); }

  /* RESULTS */
  .results-head { max-width: 640px; margin-bottom: var(--space-2xl); }
  .results-head h2 { margin: 0.5rem 0 var(--space-sm); }
  .results-head p { color: var(--color-text-light); }
  .case-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); }
  @media (min-width: 640px) { .case-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .case-grid { grid-template-columns: repeat(3, 1fr); } }
  .case-card { background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); overflow: hidden; transition: all var(--transition-base); }
  .case-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-hover); }
  .case-shot { aspect-ratio: 16/10; overflow: hidden; background: var(--color-gray-100); border-bottom: 1px solid var(--color-gray-200); }
