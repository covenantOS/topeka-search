---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import config from '../lib/config';
const b = config.business;
const team = b.team || [];
const builtBy = config.built_by;
const claimed = config.exclusivity?.claimed || [];
---
<Base title={`About ${b.name} | Topeka's SEO & PPC Agency`} description={`${b.name} is the Topeka marketing agency that publishes prices and works with one business per industry. A local arm of ServiceLine Pro.`}>
  <Header slot="header" />
  <PageHero
    eyebrow="About"
    title="A Topeka marketing agency that does business in the open"
    subtitle="We publish our prices, we take one client per industry, and we back it with a track record you can check."
    crumbs={[{ name: 'Home', href: '/' }, { name: 'About' }]}
  />

  <section class="section">
    <div class="container about-story">
      <div class="prose">
        <h2>Who we are</h2>
        <p>{b.name} is the Topeka arm of {builtBy.name}, a performance marketing company that has spent years getting local businesses to the top of Google. We brought that playbook home to Topeka, Kansas, and built it around two promises most agencies will not make: prices on the page, and one client per industry.</p>

        <h2>Why one client per industry</h2>
        <p>Local search is a zero-sum fight. Two competing businesses cannot both sit at the top of the Topeka Map Pack, and we will not pretend otherwise by selling the same playbook to rivals. When you claim your category with us, it is yours in this market. That is how we can go all in on your results without conflict.</p>
        <p>These Topeka categories are already claimed: {claimed.join(', ')}. If yours is still open, it will not stay that way forever.</p>

        <h2>Why prices upfront</h2>
        <p>Hiding pricing is a negotiating tactic. The number moves based on what the agency thinks it can get. We do it the other way. Local SEO is $2,500 a month. Websites are $250 a month. Google Ads management is a $0 agency fee. You can read every price before you ever talk to us, and the number does not change because you picked up the phone.</p>

        <h2>The track record behind the name</h2>
        <p>This is not a brand-new team learning on your budget. Through {builtBy.name} we have moved Map Pack rankings from 17.6 to 4.7 in six days, run Google Ads at a $0 agency fee that produced 461% ROI and a pipeline north of $2 million, and built websites that returned more than 1,000% on what they cost. Topeka SEO &amp; PPC runs that same system for one business per industry in the 785.</p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">The team</span>
        <h2>Who you actually work with</h2>
        <p>A Topeka family at the front, a proven fulfillment team behind it.</p>
      </div>

      <div class="founders">
        <article class="founder">
          <img src="/media/team/william-hamilton.webp" alt="William Hamilton, Founder, born and raised in Topeka" width="150" height="150" loading="lazy" />
          <div>
            <h3>William Hamilton</h3>
            <span class="founder-role">Founder</span>
            <p>Born and raised in Topeka. Started in video and media, then spent years getting service businesses to the top of Google. He runs every Topeka account personally.</p>
          </div>
        </article>
        <article class="founder">
          <img src="/media/team/victoria-hamilton.webp" alt="Victoria Hamilton, your local rep and William's sister" width="150" height="150" loading="lazy" />
          <div>
            <h3>Victoria Hamilton</h3>
            <span class="founder-role">Your local rep &middot; William's sister</span>
            <p>Your day-to-day contact. Victoria runs onboarding, reporting, and scheduling, so the person who answers knows your account and your name.</p>
          </div>
        </article>
      </div>

      <figure class="team-photo">
        <img src="/media/team/team-photo.webp" alt="The ServiceLine Pro team behind Topeka SEO & PPC" width="1200" height="675" loading="lazy" />
        <figcaption>The fulfillment team behind your campaigns, by {builtBy.name}.</figcaption>
      </figure>

      <div class="about-endorse">
        <span>A local agency by</span>
        <a href={builtBy.url} target="_blank" rel="noopener"><img src={`/${builtBy.logo}`} alt={builtBy.name} width="150" height="45" loading="lazy" /></a>
      </div>
    </div>
  </section>

  <CTABand showForm={false} />
  <Footer slot="footer" />
</Base>

<style>
  .about-story { max-width: 820px; }
  .section-header { max-width: 640px; margin-bottom: var(--space-2xl); }
  .section-header h2 { margin-bottom: var(--space-sm); }
  .section-header p { color: var(--color-text-light); font-size: var(--text-lg); }
  .founders { display: grid; grid-template-columns: 1fr; gap: var(--space-lg); margin-bottom: var(--space-2xl); }
  @media (min-width: 768px) { .founders { grid-template-columns: 1fr 1fr; } }
  .founder { display: flex; gap: var(--space-lg); align-items: flex-start; background: var(--color-white); border: 1px solid var(--color-gray-200); border-radius: var(--radius-card); padding: var(--space-lg); }
  .founder img { width: 120px; height: 120px; border-radius: var(--radius-md); object-fit: cover; flex-shrink: 0; }
  .founder h3 { font-size: var(--text-lg); }
  .founder-role { display: block; color: var(--color-primary); font-weight: 600; font-size: 0.85rem; margin: 0.1rem 0 0.6rem; }
  .founder p { color: var(--color-text-light); font-size: 0.93rem; line-height: 1.6; margin: 0; }
  .team-photo { margin: 0; border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); }
  .team-photo img { width: 100%; height: auto; display: block; }
  .team-photo figcaption { background: var(--color-white); border: 1px solid var(--color-gray-200); border-top: none; padding: var(--space-md); font-size: 0.85rem; color: var(--color-text-muted); text-align: center; }
  .about-endorse { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; margin-top: var(--space-3xl); color: var(--color-text-muted); font-size: 0.85rem; }
</style>
