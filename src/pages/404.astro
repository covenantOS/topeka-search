---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import config from '../lib/config';
const { phone, phone_raw } = config.business;
---
<Base title="Page Not Found | Topeka SEO & PPC" noindex={true}>
  <Header slot="header" />
  <section class="nf">
    <div class="container">
      <span class="nf-code">404</span>
      <h1>That page wandered off.</h1>
      <p>The page you wanted is not here. Let's get you back to something useful.</p>
      <div class="nf-actions">
        <a href="/" class="btn btn-primary btn-lg">Back to home</a>
        <a href="/pricing/" class="btn btn-outline btn-lg">See pricing</a>
        <a href={`tel:${phone_raw}`} class="btn btn-outline btn-lg">Call {phone}</a>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</Base>
<style>
  .nf { padding-block: var(--space-4xl); text-align: center; }
  .nf-code { font-family: var(--font-heading); font-weight: 800; font-size: 5rem; color: rgba(var(--color-primary-rgb), 0.18); letter-spacing: -0.04em; line-height: 1; }
  .nf h1 { margin: var(--space-md) 0; }
  .nf p { color: var(--color-text-light); max-width: 48ch; margin-inline: auto; margin-bottom: var(--space-xl); }
  .nf-actions { display: flex; flex-wrap: wrap; gap: var(--space-md); justify-content: center; }
</style>
